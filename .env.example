# Variables de entorno para Vercel / Turso
# Copia este archivo como .env y rellena tus credenciales de Turso

# Turso Database (https://turso.tech - gratis)
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# JWT Secret (cambia esto en producción)
JWT_SECRET=essai_hr_super_secret_key_2026_nofer

# Node environment
NODE_ENV=production

# Port (Vercel lo gestiona automáticamente)
PORT=3000
