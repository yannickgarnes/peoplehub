{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "data/seed-data.json",
          "server/database/schema.sql",
          "public/**",
          "node_modules/sql.js/dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/index.js"
    }
  ],
  "functions": {
    "server/index.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
